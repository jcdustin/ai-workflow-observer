{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "composite": true,
    "rootDir": ".",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@awo/schema": ["packages/schema/src/index.ts"],
      "@awo/privacy": ["packages/privacy/src/index.ts"],
      "@awo/git-adapter": ["packages/git-adapter/src/index.ts"],
      "@awo/cursor-adapter": ["packages/cursor-adapter/src/index.ts"],
      "@awo/evaluator": ["packages/evaluator/src/index.ts"]
    },
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  }
}
